# Local development defaults for the Docker stack (scripts/docker/compose.yml).
#
# These are safe, throwaway credentials for a local-only environment — never reuse them
# anywhere real. Change ports here if they clash with something else on your machine.
# Copy .env.example over this file to reset to defaults.

COMPOSE_PROJECT_NAME=wp-plugin-boilerplate

# --- Host ports ------------------------------------------------------------------
WORDPRESS_PORT=8080
PHPMYADMIN_PORT=8081
MAILPIT_PORT=8025
DB_PORT=3306

# --- Images ----------------------------------------------------------------------
WORDPRESS_IMAGE=wordpress:6.8-php8.3-apache
WORDPRESS_CLI_IMAGE=wordpress:cli-php8.3

# --- Plugin ----------------------------------------------------------------------
# Directory name the plugin is mounted as inside wp-content/plugins. Keep in step with
# the plugin slug (scripts/setup updates this for you when you rename the plugin).
PLUGIN_SLUG=wp-plugin-boilerplate

# --- Site database ---------------------------------------------------------------
MYSQL_ROOT_PASSWORD=root
WORDPRESS_DB_HOST=db
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=wordpress
WORDPRESS_TABLE_PREFIX=wp_
WORDPRESS_DEBUG=1

# --- Integration tests -----------------------------------------------------------
WP_TESTS_DB_NAME=wordpress_test
# WordPress version baked into the tools image test suite: a release, "latest" or "nightly".
WP_TESTS_VERSION=latest

# --- Debugging -------------------------------------------------------------------
# Xdebug is off by default. Set to "debug" (step debugging) or "coverage" as needed,
# e.g. XDEBUG_MODE=debug ./scripts/dev up
XDEBUG_MODE=off
