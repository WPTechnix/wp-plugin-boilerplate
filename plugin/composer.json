  "description": "A boilerplate for building modern WordPress plugins.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": "^8.0"
  },
  "autoload": {
    "psr-4": {
      "WPPluginBoilerplate\\": "src/"
    }
  },
  "config": {
